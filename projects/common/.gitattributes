# Auto-detect text files and normalise to LF
* text=auto eol=lf

# Windows files — must use CRLF
# .reg files are a hard requirement: regedit will fail to import LF-only files
# .bat/.cmd are required for compatibility with older Windows CMD interpreters
# PowerShell (.ps1/.psm1/.psd1) convention is CRLF on Windows
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.reg  text eol=crlf
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Explicit binary overrides for common image/document formats.
# No need to list every binary type — text=auto already prevents line ending
# changes on files git detects as binary (via NUL byte heuristics). These
# entries additionally set -diff to suppress noise in git diff output.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary