# files
####

# ignore coverage files
.coverage*

# ignore test coverage files
cover.*

# ignore coverage generated report files
coverage.xml

# ignore compiled python scripts
*.py[cod]

# ignore databases
*.db

# ignore log files
*.log

TODO*

# ignore all scratch related files and folders
scratch*

# ignore sqlite memory files
:memory:

# folders
####

# ignore all dot folders
.*/

# ai skills folders
*superpowers/

# temporary folders
temp/

# temporary folders
tmp/

# ignore copilot generated plans folders
*plans/

# ignore copilot generated specs folders
*specs/

# ignore pr worktree folders
pr/*/

# ignore html coverage folder
htmlcov/

# ignore docs folder that may contain copilot plans folders
docs/superpowers/*

# ignore github instructions folders
instructions/

# ignore egg info folders
*.egg-info/

# ignore python cache folders
__pycache__/

# overrides (excludes)
####

# ignore all dot folders except .github
!.github/

# exclude test data coverage folder from being ignored (nocrap)
!internal/coverage/